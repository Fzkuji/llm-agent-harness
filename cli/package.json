{
  "name": "@openprogram/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "openprogram-cli": "dist/index.js"
  },
  "scripts": {
    "build": "esbuild src/index.tsx --bundle --platform=node --target=node20 --format=esm --outfile=dist/index.js --packages=external --jsx=automatic --banner:js=\"#!/usr/bin/env node\\nimport { createRequire } from 'module'; const require = createRequire(import.meta.url);\"",
    "dev": "esbuild src/index.tsx --bundle --platform=node --target=node20 --format=esm --outfile=dist/index.js --packages=external --jsx=automatic --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ink": "^5.0.1",
    "ink-text-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1",
    "ws": "^8.18.0",
    "figures": "^6.1.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18.3.3",
    "@types/ws": "^8.5.13",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.4"
  }
}
